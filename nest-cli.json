{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/moto-hub/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/moto-hub/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/moto-hub",
  "projects": {
    "moto-hub": {
      "type": "application",
      "root": "apps/moto-hub",
      "entryFile": "main",
      "sourceRoot": "apps/moto-hub/src",
      "compilerOptions": {
        "tsConfigPath": "apps/moto-hub/tsconfig.app.json"
      }
    },
    "motohub-batch": {
      "type": "application",
      "root": "apps/motohub-batch",
      "entryFile": "main",
      "sourceRoot": "apps/motohub-batch/src",
      "compilerOptions": {
        "tsConfigPath": "apps/motohub-batch/tsconfig.app.json"
      }
    }
  }
}